{
  "name": "cosmos-shop",
  "private": false,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront",
    "postinstall": "patch-package"
  },
  "pnpm": {
    "overrides": {}
  },
  "devDependencies": {
    "@medusajs/eslint-plugin": "2.16.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.4",
    "jiti": "^2.7.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**"
  ],
  "overrides": {
    "ajv": "^8.0.0"
  }
}
